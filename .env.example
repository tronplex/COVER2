# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and populate the values.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
#            .env is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# NVD API Key (optional but strongly recommended)
# Without a key:  5 requests / 30 seconds (slower, suitable for small inventories)
# With a key:    50 requests / 30 seconds (faster, required for large inventories)
#
# Request a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here
